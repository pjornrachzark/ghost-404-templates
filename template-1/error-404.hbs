{{!< default}}

<div class="sr-page-grid">
  <section class="sr-hero-outer">
    <div class="sr-hero-inner">
      <h1 class="sr-hero-title">Page <span class="sr-highlight">not found</span></h1>
      <p class="sr-hero-desc">Looks like this page doesn't exist. Head back, contact us or keep reading our most recent articles.</p>
      <div class="sr-button-row">
        <a class="sr-home-button" href="{{@site.url}}">Back to homepage</a>
        {{!-- Replace with your email address, or link to your contact page --}}
        <a class="sr-contact-button" href="mailto:example@email.com">Contact us</a>
      </div>
    </div>
  </section>
  <aside class="read-more-outer">
    <div class="read-more-inner">
      {{#get "posts" include="authors" limit="3" as |more_posts|}}
        {{#if more_posts}}
          {{#foreach more_posts}}
            {{> "post-card"}}
          {{/foreach}}
        {{/if}}
      {{/get}}
    </div>
  </aside>
</div>

<style>
  .sr-page-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: center;
    margin-top: 60px;
  }
  .read-more-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    max-width: 640px;
    margin: 0 10px;
  }
  .read-more-inner > .post-card {
    grid-column: span 1;
    min-width: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 16px;
    padding: 30px;
    margin-top: 20px;
  }
  .read-more-inner > :first-child {
    grid-column: 1 / -1;
  }
  .read-more-inner > :first-child .post-card-image-link:after {
    padding-bottom: 40%;
  }
  .read-more-inner .post-card-excerpt,
  .read-more-inner .post-card-meta-date {
    display: none;
  }
  .sr-hero-outer {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 100px;
  }
  .sr-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 400px;
  }
  .sr-button-row {
    display: flex;
    flex-direction: row;
    gap: 20px;
    margin-top: 15px;
  }
  .sr-highlight {
    background-color: var(--ghost-accent-color);
    color: #fff;
    padding: 0.05em 0.18em;
    border-radius: 3px;
  }
  .sr-home-button, .sr-contact-button {
    border: 1px solid rgba(0, 0, 0, 0.1);
    color: black;
    padding: .8em 1.4em;
    border-radius: 100px;
  }
  @media (max-width: 1100px) {
    .sr-page-grid {
      grid-template-columns: 1fr;
      row-gap: 20px;
      padding: 0 24px;
    }
    .sr-hero-outer {
      margin-top: 40px;
      text-align: center;
    }
    .sr-button-row {
      justify-content: center;
    }
    .read-more-inner {
      margin: 0 auto;
    }
    .read-more-inner .post-card-title {
      font-size: 1.6rem;
      line-height: 1.25;
    }
  }
  @media (max-width: 500px) {
    .read-more-inner {
      grid-template-columns: 1fr;
    }
    .read-more-inner > .post-card {
      padding: 20px;
    }
    .read-more-inner > :first-child .post-card-image-link:after {
      padding-bottom: 56%;
    }
  }
</style>
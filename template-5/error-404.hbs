{{!< default}}

<section class="sr-hero-outer">
  <div class="sr-hero-inner">
    <p class="sr-404">Page not found</p>
    <h1 class="sr-site-title">{{@site.title}}</h1>
    <p class="sr-site-desc">{{@site.description}}</p>
    {{!-- Getting tags --}}
    {{#get "tags" limit="10" include="count.posts" order="count.posts desc"}}
      {{#if tags}}
        <div class="sr-topics">
          <p class="sr-topics-label">Browse Topics</p>
          <div class="sr-tags">
            {{#foreach tags}}
              {{#if count.posts}}
                <a class="sr-tag" href="{{url}}">{{name}}<span class="sr-tag-count">{{count.posts}}</span></a>
              {{/if}}
            {{/foreach}}
          </div>
        </div>
      {{/if}}
    {{/get}}
  </div>
</section>

<style>
  .sr-hero-outer {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }
  .sr-hero-inner {
    display: flex;
    flex-direction: column;
    text-align: center;
    gap: 10px;
  }
  .sr-404 {
    align-self: center;
    background-color: var(--ghost-accent-color);
    color: white;
    border: 0;
    border-radius: 100px;
    font-weight: 600;
    font-size: 1.5rem;
    padding: 0.2em 0.6em;
    text-transform: uppercase;
  }
  .sr-site-title {
    font-size: clamp(3rem, 7vw, 6rem);
  }
  .sr-site-desc {
    font-size: clamp(1.5rem, 4vw, 3rem);
    margin-bottom: 50px;
  }
  .sr-topics-label {
    text-transform: uppercase;
    font-size: clamp(0.8rem, 2vw, 2rem);
    letter-spacing: 0.12em;
    font-weight: 600;
    opacity: 50%;
    margin-bottom: 20px;
  }
  .sr-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    max-width: 500px;
    margin: 0 auto;
  }
  .sr-tag {
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    font-size: clamp(1.1rem, 2.1vw, 1.5rem);
    padding: 0.2em 0.6em;
  }
  .sr-tag-count {
    margin-left: 5px;
    opacity: 50%;
  }
</style>